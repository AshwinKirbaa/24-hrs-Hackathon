							},
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Rahul Verma\",\n  \"email\": \"rahul.verma@student.edu\",\n  \"department\": \"Computer Science\",\n  \"semester\": 4\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/students",
