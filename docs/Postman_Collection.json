								"{{baseUrl}}"
							],
							"path": [
								"dashboard"
							]
						}
					}
				}
			]
		},
		{
			"name": "Students",
			"item": [
				{
					"name": "Get All Students (Paginated & Filtered)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/students?department=Computer Science&page=1&limit=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"students"
							],
							"query": [
								{
									"key": "department",
									"value": "Computer Science"
								},
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						}
					}
				},
				{
					"name": "Get Student by ID",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/students/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"students",
								"1"
							]
						}
					}
				},
